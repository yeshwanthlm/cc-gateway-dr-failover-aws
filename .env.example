# =============================================================================
# Confluent Cloud Gateway Demo - Environment Configuration (AWS)
# =============================================================================
# Copy this file to .env and fill in your actual values
#   cp .env.example .env
#   # Edit .env with your configuration
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# AWS region for EKS cluster deployment
# Use a different region than the Confluent Cloud clusters
# (e.g., us-east-2, us-east-1, us-west-2)
AWS_REGION=us-east-2

# Name for your EKS cluster
EKS_CLUSTER_NAME=cc-gateway-eks

# -----------------------------------------------------------------------------
# Confluent Cloud Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API credentials from https://confluent.cloud/settings/api-keys
# Use Cloud API keys (not cluster-specific keys)
CONFLUENT_CLOUD_API_KEY=YOUR_CONFLUENT_CLOUD_API_KEY
CONFLUENT_CLOUD_API_SECRET=YOUR_CONFLUENT_CLOUD_API_SECRET

# -----------------------------------------------------------------------------
# Gateway Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Route53 private hosted zone name (default: axa.com)
DNS_ZONE_NAME=axa.com

# Gateway DNS record name (kafka.cc for kafka.cc.axa.com)
GATEWAY_DNS_RECORD_NAME=kafka.cc

# Full gateway domain name (will be GATEWAY_DNS_RECORD_NAME.DNS_ZONE_NAME)
GATEWAY_DOMAIN=kafka.cc.axa.com

# -----------------------------------------------------------------------------
# EKS Cluster Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Kubernetes version for EKS cluster (default: 1.31)
KUBERNETES_VERSION=1.31

# EC2 instance type for EKS worker nodes (default: t3.large)
# Options: t3.medium, t3.large, t3.xlarge, m5.large, etc.
INSTANCE_TYPE=t3.large

# -----------------------------------------------------------------------------
# Confluent Cloud Kafka Clusters (OPTIONAL)
# -----------------------------------------------------------------------------
# Confluent Cloud environment name (default: cc-gateway-demo-aws)
CONFLUENT_ENVIRONMENT_NAME=cc-gateway-demo-aws

# Primary AWS Kafka cluster configuration (STANDARD TYPE)
# - Type: Standard (elastic, pay-per-use, auto-scaling)
# - Region: us-east-1 (N. Virginia) - AWS region for primary cluster
# - Use: Main production cluster, variable workloads
PRIMARY_CLUSTER_NAME=aws-useast1-primary
PRIMARY_CLUSTER_REGION=us-east-1

# DR AWS Kafka cluster configuration (DEDICATED TYPE)
# - Type: Dedicated (1 CKU, fixed capacity, 99.95% SLA)
# - Region: us-west-2 (Oregon) - AWS region for DR cluster
# - Use: Disaster recovery with cluster linking
DR_CLUSTER_NAME=aws-uswest2-dr
DR_CLUSTER_REGION=us-west-2

# Kafka cluster availability configuration (default: SINGLE_ZONE)
# Options: SINGLE_ZONE (cheaper) or MULTI_ZONE (higher availability)
# Note: This applies to Standard cluster; Dedicated cluster has its own availability settings
KAFKA_AVAILABILITY=SINGLE_ZONE

# Cluster Linking Configuration
# - Cluster Link: primary-to-dr-link (Primary → DR)
# - Mirror Topic: mirrored_topic (automatically replicated from Primary to DR)
# - Configured automatically by Terraform
# - No manual configuration needed

# -----------------------------------------------------------------------------
# Certificate Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# These are used for generating TLS certificates
# JKS keystore/truststore password (default: confluent)
JKS_PASSWORD=confluent

# Client truststore password (default: clienttrustpass)
CLIENT_TRUSTSTORE_PASSWORD=clienttrustpass

# Certificate details for gateway TLS certificate
CERT_COUNTRY=US
CERT_STATE=CA
CERT_CITY=Mountain View
CERT_ORG=Confluent
CERT_OU=Engineering

# -----------------------------------------------------------------------------
# Auto-populated Variables (DO NOT EDIT)
# -----------------------------------------------------------------------------
# These variables are automatically populated by the deploy.sh script
# after Terraform creates the Confluent Cloud clusters
# PRIMARY_CLUSTER_ENDPOINT=
# DR_CLUSTER_ENDPOINT=
# PRIMARY_CLUSTER_API_KEY=
# PRIMARY_CLUSTER_API_SECRET=
# DR_CLUSTER_API_KEY=
# DR_CLUSTER_API_SECRET=
# PRIMARY_SERVICE_ACCOUNT_ID=
# DR_SERVICE_ACCOUNT_ID=
# CC_SCHEMA_REGISTRY_ENDPOINT=
# CC_SCHEMA_REGISTRY_API_KEY=
# CC_SCHEMA_REGISTRY_API_SECRET=
